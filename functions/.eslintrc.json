{
  "root": true,
  "env": {
    "es2022": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "google",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": ["tsconfig.json"],
    "sourceType": "module"
  },
  "ignorePatterns": [
    "/lib/**/*"
  ],
  "plugins": [
    "@typescript-eslint"
  ],
  "rules": {
    "quotes": ["error", "double"],
    "@typescript-eslint/no-explicit-any": "off",
    "indent": ["error", 2],
    "max-len": ["warn", { "code": 120 }],
    "require-jsdoc": "off",
    "linebreak-style": "off"
  }
}
