class AdminDashboardScreen extends ConsumerStatefulWidget {
  const AdminDashboardScreen({super.key});

  @override
  ConsumerState<AdminDashboardScreen> createState() =>
      _AdminDashboardScreenState();
}

class _AdminDashboardScreenState extends ConsumerState<AdminDashboardScreen> {
  final Set<String> _approving = <String>{};

  Future<void> _approve({
    required BuildContext context,
    required String groupId,
    required String userId,
  }) async {
    if (_approving.contains(userId)) return;
    await HapticFeedback.lightImpact();
    setState(() => _approving.add(userId));
    try {
      final callable = FirebaseFunctions.instanceFor(
        region: 'us-central1',
      ).httpsCallable('approveMember');
      await callable.call(<String, dynamic>{
        'groupId': groupId,
        'userId': userId,
      });
      if (context.mounted) {
        AppSnackbar.show(context, message: '?筌먲퐢沅?, type: AppSnackType.success);
      }
    } on FirebaseFunctionsException catch (e) {
      if (context.mounted) {
        AppSnackbar.show(
          context,
          message: '?筌뤾쑴理????덉넮: ${e.code}',
          type: AppSnackType.error,
        );
      }
    } finally {
      if (mounted) {
        setState(() => _approving.remove(userId));
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    final user = FirebaseAuth.instance.currentUser;
    final groupId = ref.watch(selectedGroupIdProvider);
    if (user == null || groupId == null) {
      return const Scaffold(body: Center(child: Text('?β돦裕??筌뤾쑴逾??熬곣뫗???紐껊퉵??')));
    }

    final memberStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('members')
        .doc(user.uid)
        .snapshots();
    final periodKey = _currentPeriodKey();
    final nowTs = Timestamp.now();

    return StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
      stream: memberStream,
      builder: (context, myMember) {
        final permission = PermissionService.fromMemberData(
          myMember.data?.data(),
        );
        final canOpenDashboard = permission.canAccessAdminDashboard();
        final canManageMembers = permission.canManageMembers();
        final canManageFinance = permission.canManageFinance();
        final canManageRoles = permission.canManageRoles();

        if (!canOpenDashboard) {
          return const Scaffold(body: Center(child: Text('??⑥щ턄??? ??怨룸????덈펲.')));
        }

        final statsRef = FirebaseFirestore.instance
            .collection('groups')
            .doc(groupId)
            .collection('stats')
            .doc(periodKey);
        final pendingRef = FirebaseFirestore.instance
            .collection('groups')
            .doc(groupId)
            .collection('members')
            .where('status', isEqualTo: 'pending');
        final activeRef = FirebaseFirestore.instance
            .collection('groups')
            .doc(groupId)
            .collection('members')
            .where('status', isEqualTo: 'active');
        final paymentsRef = FirebaseFirestore.instance
            .collection('groups')
            .doc(groupId)
            .collection('feePeriods')
            .doc(periodKey)
            .collection('payments');
        final upcomingRef = FirebaseFirestore.instance
            .collection('groups')
            .doc(groupId)
            .collection('events')
            .where('startAt', isGreaterThan: nowTs)
            .limit(50);
        final auditRef = FirebaseFirestore.instance
            .collection('groups')
            .doc(groupId)
            .collection('auditLogs')
            .orderBy('at', descending: true)
            .limit(50);

        return DefaultTabController(
          length: 4,
          child: Scaffold(
            appBar: AppBar(
              title: const Row(
                children: [
                  Icon(Icons.admin_panel_settings_outlined, size: 18),
                  SizedBox(width: 6),
                  Text('Admin Dashboard'),
                ],
              ),
              bottom: const TabBar(
                tabs: [
                  Tab(text: 'Overview'),
                  Tab(text: 'Approvals'),
                  Tab(text: 'Fees'),
                  Tab(text: 'Audit'),
                ],
              ),
            ),
            body: TabBarView(
              children: [
                ListView(
                  padding: const EdgeInsets.all(16),
                  children: [
                    const SectionHeader(
                      title: '?띠룇裕??,
                      icon: Icons.dashboard_outlined,
                    ),
                    StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
                      stream: statsRef.snapshots(),
                      builder: (context, statsSnap) {
                        final data =
                            statsSnap.data?.data() ?? <String, dynamic>{};
                        return SingleChildScrollView(
                          scrollDirection: Axis.horizontal,
                          child: Row(
                            children: [
                              StatTile(
                                title: '??戮?뎽 嶺뚮、?뉓떋?,
                                value: '${data['activeMemberCount'] ?? '-'}',
                              ),
                              StatTile(
                                title: '亦껋꼶梨뜻쾮??筌뤾쑴??,
                                value: '${data['unpaidCount'] ?? '-'}',
                              ),
                              StatTile(
                                title: '?????????源놁젧',
                                value: '${data['eventCountThisMonth'] ?? '-'}',
                              ),
                            ],
                          ),
                        );
                      },
                    ),
                    FutureBuilder<QuerySnapshot<Map<String, dynamic>>>(
                      future: upcomingRef.get(),
                      builder: (context, upcomingSnap) {
                        final count =
                            (upcomingSnap.data?.docs ??
                                    const <
                                      QueryDocumentSnapshot<
                                        Map<String, dynamic>
                                      >
                                    >[])
                                .where((e) => e.data()['isDeleted'] != true)
                                .length;
                        return AppCard(
                          child: ListTile(
                            title: const Text('??????노츎 ??源놁젧'),
                            subtitle: Text('$count濾?),
                          ),
                        );
                      },
                    ),
                  ],
                ),
                StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
                  stream: pendingRef.snapshots(),
                  builder: (context, pendingSnap) {
                    if (!canManageMembers) {
                      return const Center(child: Text('雅?굝??뇡????怨룸????덈펲.'));
                    }
                    if (pendingSnap.hasError)
                      return Center(
                        child: Text(_friendlyError(pendingSnap.error)),
                      );
                    if (!pendingSnap.hasData)
                      return const Center(child: CircularProgressIndicator());
                    final docs = pendingSnap.data!.docs;
                    if (docs.isEmpty) {
                      return const EmptyState(
                        icon: Icons.verified_user_outlined,
                        title: '?獄???????嶺뚮、?뉓떋???怨몃쾳',
                        description: '?熬곣뫗???獄????????嶺뚮、?뉓떋?泥? ??怨룸????덈펲.',
                      );
                    }
                    return ListView.builder(
                      padding: const EdgeInsets.all(16),
                      itemCount: docs.length + 1,
                      itemBuilder: (context, index) {
                        if (index == 0)
                          return const SectionHeader(
                            title: '?띠럾????獄???,
                            icon: Icons.verified_user_outlined,
                          );
                        final doc = docs[index - 1];
                        final loading = _approving.contains(doc.id);
                        return AppCard(
                          child: ListTile(
                            title: Text(
                              doc.data()['displayName'] as String? ?? doc.id,
                            ),
                            subtitle: Text('uid: ${doc.id}'),
                            trailing: ElevatedButton(
                              onPressed: loading
                                  ? null
                                  : () => _approve(
                                      context: context,
                                      groupId: groupId,
                                      userId: doc.id,
                                    ),
                              child: Text(loading ? '嶺뚳퐣瑗?怨?뭄? : '?獄???),
                            ),
                          ),
                        );
                      },
                    );
                  },
                ),
                StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
                  stream: activeRef.snapshots(),
                  builder: (context, activeSnap) {
                    if (!canManageFinance) {
                      return const Center(child: Text('雅?굝??뇡????怨룸????덈펲.'));
                    }
                    if (activeSnap.hasError)
                      return Center(
                        child: Text(_friendlyError(activeSnap.error)),
                      );
                    if (!activeSnap.hasData)
                      return const Center(child: CircularProgressIndicator());
                    final members = activeSnap.data!.docs;
                    if (members.isEmpty) {
                      return const EmptyState(
                        icon: Icons.group_off_outlined,
                        title: '??戮?뎽 嶺뚮、?뉓떋???怨몃쾳',
                        description: '????????㉱?洹먮뿫留???戮?뎽 嶺뚮、?뉓떋?泥? ??怨룸????덈펲.',
                      );
                    }
                    return FutureBuilder<QuerySnapshot<Map<String, dynamic>>>(
                      future: paymentsRef.get(),
                      builder: (context, paymentSnap) {
                        if (paymentSnap.hasData &&
                            paymentSnap.data!.docs.isEmpty) {
                          return const EmptyState(
                            icon: Icons.payments_outlined,
                            title: '???????⑥щ턄????怨몃쾳',
                            description: '?????????? ??⑥щ턄??? ??怨룸????덈펲.',
                          );
                        }
                        final paid =
                            paymentSnap.data?.docs.map((d) => d.id).toSet() ??
                            <String>{};
                        final unpaidMembers = members
                            .where((m) => !paid.contains(m.id))
                            .toList();
                        if (unpaidMembers.isEmpty) {
                          return const EmptyState(
                            icon: Icons.task_alt_outlined,
                            title: '嶺뚮ㅄ維獄?嶺뚮、?뉓떋???? ?熬곣뫁??,
                            description: '亦껋꼶梨뜻쾮?嶺뚮、?뉓떋?泥? ??怨룸????덈펲.',
                          );
                        }
                        return ListView.builder(
                          padding: const EdgeInsets.all(16),
                          itemCount: unpaidMembers.length + 1,
                          itemBuilder: (context, index) {
                            if (index == 0)
                              return const SectionHeader(
                                title: '亦껋꼶梨뜻쾮?嶺뚮、?뉓떋?,
                                icon: Icons.payments_outlined,
                              );
                            final m = unpaidMembers[index - 1];
                            return AppCard(
                              child: ListTile(
                                title: Text(
                                  m.data()['displayName'] as String? ?? m.id,
                                ),
                                subtitle: Text('uid: ${m.id}'),
                              ),
                            );
                          },
                        );
                      },
                    );
                  },
                ),
                StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
                  stream: auditRef.snapshots(),
                  builder: (context, auditSnap) {
                    if (!canManageRoles) {
                      return const Center(child: Text('雅?굝??뇡????怨룸????덈펲.'));
                    }
                    if (auditSnap.hasError)
                      return Center(
                        child: Text(_friendlyError(auditSnap.error)),
                      );
                    if (!auditSnap.hasData)
                      return const Center(child: CircularProgressIndicator());
                    final docs = auditSnap.data!.docs;
                    if (docs.isEmpty)
                      return const Center(child: Text('?띠룆흮亦??β돦裕??먯쾸? ??怨룸????덈펲.'));
                    return ListView.builder(
                      padding: const EdgeInsets.all(16),
                      itemCount: docs.length + 1,
                      itemBuilder: (context, index) {
                        if (index == 0)
                          return const SectionHeader(
                            title: '?띠룆흮亦??β돦裕??,
                            icon: Icons.history_outlined,
                          );
                        final data = docs[index - 1].data();
                        final action = data['action'] as String? ?? '-';
                        final actor = data['actorUid'] as String? ?? '-';
                        final target = data['targetUid'] as String? ?? '-';
                        return AppCard(
                          child: ListTile(
                            title: Text(action),
                            subtitle: Text('actor: $actor / target: $target'),
                          ),
                        );
                      },
                    );
                  },
                ),
              ],
            ),
          ),
        );
      },
    );
  }
}

class NotificationSettingsScreen extends ConsumerWidget {
  const NotificationSettingsScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final groupId = ref.watch(selectedGroupIdProvider);
    final user = FirebaseAuth.instance.currentUser;
    if (groupId == null || user == null) {
      return const Scaffold(body: Center(child: Text('??怨뚰맟?熬곣뫗諭????깆젧???낅슣?섋땻??')));
    }

    final settingsRef = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('members')
        .doc(user.uid)
        .collection('notificationSettings')
        .doc('default');

    Future<void> saveSettings({
      required bool noticeEnabled,
      required bool eventReminderEnabled,
      required bool noResponseReminderEnabled,
    }) async {
      try {
        await settingsRef.set({
          'noticeEnabled': noticeEnabled,
          'eventReminderEnabled': eventReminderEnabled,
          'noResponseReminderEnabled': noResponseReminderEnabled,
          'updatedAt': FieldValue.serverTimestamp(),
        }, SetOptions(merge: true));
      } on FirebaseException catch (e) {
        if (!context.mounted) return;
        final msg = e.code == 'permission-denied'
            ? kPermissionDeniedMessage
            : '???逾????깆젧 ???????덉넮: ${e.code}';
        AppSnackbar.show(context, message: msg, type: AppSnackType.error);
      }
    }

    return Scaffold(
      appBar: AppBar(
        title: const Row(
          children: [
            Icon(Icons.notifications_outlined, size: 18),
            SizedBox(width: 6),
            Text('???逾????깆젧'),
          ],
        ),
      ),
      body: StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
        stream: settingsRef.snapshots(),
        builder: (context, snapshot) {
          if (snapshot.hasError)
            return Center(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Text(_friendlyError(snapshot.error)),
              ),
            );
          if (!snapshot.hasData)
            return const Center(child: CircularProgressIndicator());
          final data = snapshot.data!.data() ?? <String, dynamic>{};
          final noticeEnabled = data['noticeEnabled'] as bool? ?? true;
          final eventReminderEnabled =
              data['eventReminderEnabled'] as bool? ?? true;
          final noResponseReminderEnabled =
              data['noResponseReminderEnabled'] as bool? ?? true;

          return ListView(
            padding: const EdgeInsets.all(16),
            children: [
              const SectionHeader(
                title: '???逾????깆젧',
                icon: Icons.notifications_outlined,
              ),
              AppCard(
                child: Column(
                  children: [
                    SwitchListTile(
                      contentPadding: EdgeInsets.zero,
                      title: const Text('??ㅻ쾴? ???逾?),
                      value: noticeEnabled,
                      onChanged: (v) => saveSettings(
                        noticeEnabled: v,
                        eventReminderEnabled: eventReminderEnabled,
                        noResponseReminderEnabled: noResponseReminderEnabled,
                      ),
                    ),
                    const Divider(height: 1),
                    SwitchListTile(
                      contentPadding: EdgeInsets.zero,
                      title: const Text('D-1 ??源놁젧 ???逾?),
                      value: eventReminderEnabled,
                      onChanged: (v) => saveSettings(
                        noticeEnabled: noticeEnabled,
                        eventReminderEnabled: v,
                        noResponseReminderEnabled: noResponseReminderEnabled,
                      ),
                    ),
                    const Divider(height: 1),
                    SwitchListTile(
                      contentPadding: EdgeInsets.zero,
                      title: const Text('?獄???13:00 亦껋꼶梨??????逾?),
                      value: noResponseReminderEnabled,
                      onChanged: (v) => saveSettings(
                        noticeEnabled: noticeEnabled,
                        eventReminderEnabled: eventReminderEnabled,
                        noResponseReminderEnabled: v,
                      ),
                    ),
                  ],
                ),
              ),
            ],
          );
        },
      ),
    );
  }
}

class _ResponseButton extends StatelessWidget {
  const _ResponseButton({
    required this.label,
    required this.selected,
    required this.onPressed,
  });

  final String label;
  final bool selected;
  final VoidCallback? onPressed;

  @override
  Widget build(BuildContext context) {
    return OutlinedButton(
      style: OutlinedButton.styleFrom(
        backgroundColor: selected ? AppTheme.primaryLight : null,
        foregroundColor: Theme.of(context).colorScheme.primary,
        side: BorderSide(color: Theme.of(context).colorScheme.outlineVariant),
      ),
      onPressed: onPressed,
      child: Text(label),
    );
  }
}

Future<void> _writeResponse({
  required String groupId,
  required String eventId,
  required String uid,
  required String response,
  required BuildContext context,
}) async {
  final span = PerfSpan('Write response').start();
  try {
    await HapticFeedback.lightImpact();
    await FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('events')
        .doc(eventId)
        .collection('responses')
        .doc(uid)
        .set({
          'response': response,
          'respondedAt': FieldValue.serverTimestamp(),
        }, SetOptions(merge: true));
    FirestoreMetrics.instance.addWrites();
    if (context.mounted) {
      AppSnackbar.show(
        context,
        message: '??얜Ŧ堉?????縕ョ뵳???곕????덈펲.',
        type: AppSnackType.success,
      );
    }
  } on FirebaseException catch (e) {
    final message = toUserMessage(e);
    if (context.mounted) {
      AppSnackbar.show(context, message: message, type: AppSnackType.error);
    }
  } finally {
    span.end();
    FirestoreMetrics.instance.dump('response');
  }
}

String _eventPrimaryPlace(Map<String, dynamic> eventData) {
  final locationName = eventData['locationName']?.toString();
  final location = eventData['location']?.toString();
  final address = eventData['address']?.toString();

  if (locationName != null && locationName.isNotEmpty) return locationName;
  if (location != null && location.isNotEmpty) return location;
  if (address != null && address.isNotEmpty) return address;
  return '-';
}

String? _eventMapQuery(Map<String, dynamic> eventData) {
  final address = eventData['address']?.toString();
  final locationName = eventData['locationName']?.toString();
  final location = eventData['location']?.toString();

  if (address != null && address.isNotEmpty) return address;
  if (locationName != null && locationName.isNotEmpty) return locationName;
  if (location != null && location.isNotEmpty) return location;
  return null;
}

String _formatDate(DateTime date) {
  final m = date.month.toString().padLeft(2, '0');
  final d = date.day.toString().padLeft(2, '0');
  final h = date.hour.toString().padLeft(2, '0');
  final min = date.minute.toString().padLeft(2, '0');
  return '$m.$d $h:$min';
}

String _currentPeriodKey([DateTime? date]) {
  final now = date ?? DateTime.now();
  final month = now.month.toString().padLeft(2, '0');
  return '${now.year}-$month';
}

String _friendlyError(Object? error) {
  if (error == null) return kDefaultUserErrorMessage;
  return toUserMessage(error);
}

