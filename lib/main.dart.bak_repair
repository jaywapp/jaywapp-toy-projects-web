  final List<(String, String)> _slides = const [
    ('??ㅻ쾴??? ??源놁젧 ??㉱??, '嶺뚮ㅄ維????ㅻ쾴??? ??源놁젧????蹂κ텛???????㉱?洹먮뿫由?筌뤾쑴??'),
    ('??ㅻ쾴??? ??源놁젧 ??㉱??, '?怨쀫츋?묐씣????????嶺뚳퐢????⑤챷紐드슖???㉱?洹먮뿫由?筌뤾쑴??'),
    ('??怨멸껀??????關紐??⑤챷紐드슖?, '??ㅻ쾴? ?筌먦끉逾? ?怨쀫츋??嶺뚳퐢?얍칰? ???????㉱?洹먮뜇?긺춯?뼿 ???뺢퀡?녻굢?'),
  ];

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  Future<void> _complete() async {
    if (_saving) return;
    setState(() => _saving = true);
    final prefs = await SharedPreferences.getInstance();
    await prefs.setBool('onboarding_seen', true);
    ref.invalidate(onboardingSeenProvider);
    if (mounted) context.go('/');
  }

  @override
  Widget build(BuildContext context) {
    final isLast = _index == _slides.length - 1;
    return Scaffold(
      backgroundColor: Theme.of(context).scaffoldBackgroundColor,
      body: SafeArea(
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Column(
            children: [
              Expanded(
                child: PageView.builder(
                  controller: _controller,
                  itemCount: _slides.length,
                  onPageChanged: (i) => setState(() => _index = i),
                  itemBuilder: (context, i) {
                    final slide = _slides[i];
                    return Column(
                      mainAxisAlignment: MainAxisAlignment.center,
                      children: [
                        ClipRRect(
                          borderRadius: BorderRadius.circular(20),
                          child: Image.asset(
                            'assets/branding/app_icon.png',
                            width: 96,
                            height: 96,
                            fit: BoxFit.cover,
                          ),
                        ),
                        const SizedBox(height: 24),
                        Text(
                          slide.$1,
                          style: Theme.of(context).textTheme.headlineMedium,
                          textAlign: TextAlign.center,
                        ),
                        const SizedBox(height: 12),
                        Text(
                          slide.$2,
                          style: Theme.of(context).textTheme.bodyMedium
                              ?.copyWith(
                                color: Theme.of(
                                  context,
                                ).colorScheme.onSurfaceVariant,
                              ),
                          textAlign: TextAlign.center,
                        ),
                      ],
                    );
                  },
                ),
              ),
              Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: List.generate(
                  _slides.length,
                  (i) => Container(
                    margin: const EdgeInsets.symmetric(horizontal: 4),
                    width: _index == i ? 18 : 8,
                    height: 8,
                    decoration: BoxDecoration(
                      color: _index == i
                          ? AppTheme.primary
                          : Theme.of(context).colorScheme.outlineVariant,
                      borderRadius: BorderRadius.circular(99),
                    ),
                  ),
                ),
              ),
              const SizedBox(height: 16),
              SizedBox(
                width: double.infinity,
                child: SizedBox(
                  height: 46,
                  child: AppLoadingButton(
                    loading: _saving,
                    label: isLast ? '??戮곗굚???얄뵛' : '???깅쾳',
                    onPressed: () async {
                      if (isLast) {
                        await _complete();
                      } else {
                        await _controller.nextPage(
                          duration: const Duration(milliseconds: 260),
                          curve: Curves.easeOut,
                        );
                      }
                    },
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}

class GroupSwitcherScreen extends ConsumerStatefulWidget {
  const GroupSwitcherScreen({super.key});

  @override
  ConsumerState<GroupSwitcherScreen> createState() =>
      _GroupSwitcherScreenState();
}

class _GroupSwitcherScreenState extends ConsumerState<GroupSwitcherScreen> {
  final _groupIdController = TextEditingController(text: 'g_demo');
  bool _checking = false;
  String? _message;
  bool? _memberExists;
  String? _memberStatus;
  String? _validatedGroupId;
  String? _validatedGroupName;

  @override
  void dispose() {
    _groupIdController.dispose();
    super.dispose();
  }

  Future<Map<String, String>> _loadGroupNames(List<String> groupIds) async {
    final result = <String, String>{};
    for (final groupId in groupIds) {
      final groupDoc = await FirebaseFirestore.instance
          .collection('groups')
          .doc(groupId)
          .get();
      final name = groupDoc.data()?['name'] as String? ?? groupId;
      result[groupId] = name;
    }
    return result;
  }

  Future<void> _validateGroup() async {
    final user = FirebaseAuth.instance.currentUser;
    final groupId = _groupIdController.text.trim();
    if (user == null || groupId.isEmpty) {
      setState(() => _message = '?잙갭梨띄쳥?ID?????놁졑??怨삵룖?筌뤾쑴??');
      return;
    }

    setState(() {
      _checking = true;
      _message = null;
      _memberExists = null;
      _memberStatus = null;
      _validatedGroupId = null;
      _validatedGroupName = null;
    });

    try {
      final groupRef = FirebaseFirestore.instance
          .collection('groups')
          .doc(groupId);
      final memberDoc = await groupRef
          .collection('members')
          .doc(user.uid)
          .get();
      final status = memberDoc.data()?['status'] as String?;
      _memberExists = memberDoc.exists;
      _memberStatus = status;

      if (!memberDoc.exists || status != 'active') {
        setState(() => _message = kMembershipRequiredMessage);
        ref.read(debugFirestoreErrorProvider.notifier).setError(null);
        return;
      }

      final groupDoc = await groupRef.get();
      if (!groupDoc.exists) {
        setState(() => _message = '?잙갭梨띄쳥???쒖굣?묐슗泥? ?브퀡????? ???용????덈펲.');
        return;
      }

      setState(() {
        _validatedGroupId = groupId;
        _validatedGroupName = groupDoc.data()?['name'] as String? ?? groupId;
        _message = '?잙갭梨띄쳥??롪틵?嶺??繹먭퍓沅? ??ルㅎ臾??뺢퀗????怨쀬Ŧ 嶺뚯쉳????琉얠돪??';
      });
      ref.read(debugFirestoreErrorProvider.notifier).setError(null);
    } on FirebaseException catch (e) {
      ref
          .read(debugFirestoreErrorProvider.notifier)
          .setError('${e.code}: ${e.message ?? ''}');
      setState(() {
        _message = e.code == 'permission-denied'
            ? kPermissionDeniedMessage
            : '?잙갭梨띄쳥??롪틵?嶺????덉넮: ${e.code}';
      });
    } finally {
      if (mounted) setState(() => _checking = false);
    }
  }

  @override
  Widget build(BuildContext context) {
    final user = FirebaseAuth.instance.currentUser;
    final selectedGroupId = ref.watch(selectedGroupIdProvider);
    final lastError = ref.watch(debugFirestoreErrorProvider);
    final currentFcmToken = ref.watch(currentFcmTokenProvider);
    final tokenStored = ref.watch(tokenStoredProvider);

    if (user == null) {
      return const Scaffold(body: Center(child: Text('?β돦裕??筌뤾쑴逾??熬곣뫗???紐껊퉵??')));
    }
    final membershipsStream = FirebaseFirestore.instance
        .collection('users')
        .doc(user.uid)
        .collection('memberships')
        .where('status', isEqualTo: 'active')
        .snapshots();

    return Scaffold(
      appBar: AppBar(
        title: const Row(
          children: [
            Icon(Icons.groups_outlined, size: 18),
            SizedBox(width: 6),
            Text('?잙갭梨띄쳥???ルㅎ臾?),
          ],
        ),
      ),
      body: ListView(
        padding: const EdgeInsets.all(16),
        children: [
          StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
            stream: membershipsStream,
            builder: (context, snapshot) {
              if (snapshot.hasError) {
                return AppCard(
                  child: ListTile(
                    title: const Text('?잙갭梨띄쳥??釉띾쐞???釉띯뵛 ???덉넮'),
                    subtitle: Text(_friendlyError(snapshot.error)),
                  ),
                );
              }
              if (!snapshot.hasData) {
                return const AppCard(
                  child: ListTile(
                    title: Text('?띠럾????낆춨 ?잙갭梨띄쳥?),
                    subtitle: Text('?釉띾쐞????노츎 繞?..'),
                  ),
                );
              }
              final docs = snapshot.data!.docs;
              if (docs.isEmpty) {
                return const EmptyState(
                  icon: Icons.groups_2_outlined,
                  title: '嶺뚣볦굣??繞벿살탳???잙갭梨띄쳥????怨룸????덈펲',
                  description: '??怨멸껀嶺뚯쉳?닺굢?㏃물??잙갭梨띄쳥??貫??????븐슙????삵깴???잙갭梨띄쳥?ID??嶺뚣볦굣???琉얠돪??',
                );
              }
              final groupIds = docs.map((d) => d.id).toList();
              return FutureBuilder<Map<String, String>>(
                future: _loadGroupNames(groupIds),
                builder: (context, namesSnapshot) {
                  final names = namesSnapshot.data ?? <String, String>{};
                  return AppCard(
                    child: Padding(
                      padding: const EdgeInsets.all(12),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          const Text('嶺뚣볦굣??繞벿살탳???잙갭梨띄쳥?),
                          const SizedBox(height: 8),
                          for (final groupId in groupIds)
                            ListTile(
                              contentPadding: EdgeInsets.zero,
                              title: Text(
                                names[groupId] ?? groupId,
                                maxLines: 1,
                                overflow: TextOverflow.ellipsis,
                              ),
                              subtitle: Text('ID: $groupId'),
                              trailing: SizedBox(
                                height: 44,
                                child: ElevatedButton(
                                  onPressed: () {
                                    HapticFeedback.lightImpact();
                                    AppCacheService.instance.invalidatePrefix(
                                      'group:',
                                    );
                                    AppCacheService.instance.invalidatePrefix(
                                      'member:',
                                    );
                                    AppCacheService.instance.invalidatePrefix(
                                      'settings:',
                                    );
                                    ref
                                        .read(selectedGroupIdProvider.notifier)
                                        .setGroup(groupId);
                                  },
                                  child: const Text('??ルㅎ臾?),
                                ),
                              ),
                            ),
                        ],
                      ),
                    ),
                  );
                },
              );
            },
          ),
          const SizedBox(height: 12),
          AppCard(
            child: Padding(
              padding: const EdgeInsets.all(12),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Text('?잙갭梨띄쳥?ID??嶺뚣볦굣???筌먦끉逾?),
                  const SizedBox(height: 8),
                  TextField(
                    controller: _groupIdController,
                    textInputAction: TextInputAction.done,
                    onSubmitted: (_) => _checking ? null : _validateGroup(),
                    onChanged: (_) => setState(() {}),
                    decoration: const InputDecoration(
                      labelText: 'Group ID (?? g_demo)',
                    ),
                  ),
                  const SizedBox(height: 8),
                  SizedBox(
                    width: double.infinity,
                    height: 44,
                    child: AppLoadingButton(
                      loading: _checking,
                      enabled: _groupIdController.text.trim().isNotEmpty,
                      label: '?잙갭梨띄쳥??롪틵?嶺?,
                      onPressed: _validateGroup,
                    ),
                  ),
                  if (_message != null) ...[
                    const SizedBox(height: 8),
                    Text(_message!),
                  ],
                ],
              ),
            ),
          ),
          if (_validatedGroupId != null)
            AppCard(
              child: ListTile(
                title: Text(_validatedGroupName ?? _validatedGroupId!),
                subtitle: Text('ID: ${_validatedGroupId!}'),
                trailing: SizedBox(
                  height: 44,
                  child: ElevatedButton(
                    onPressed: () {
                      HapticFeedback.lightImpact();
                      AppCacheService.instance.invalidatePrefix('group:');
                      AppCacheService.instance.invalidatePrefix('member:');
                      AppCacheService.instance.invalidatePrefix('settings:');
                      ref
                          .read(selectedGroupIdProvider.notifier)
                          .setGroup(_validatedGroupId);
                    },
                    child: const Text('??ルㅎ臾?),
                  ),
                ),
              ),
            ),
          if (kEnableDebugPanel)
            DebugPanelCard(
              uid: user.uid,
              selectedGroupId: selectedGroupId,
              memberDocExists: _memberExists,
              memberStatus: _memberStatus,
              lastFirestoreError: lastError,
              currentFcmToken: currentFcmToken,
              tokenStored: tokenStored,
              notificationSettingsSummary: null,
            ),
        ],
      ),
    );
  }
}

class AppShell extends ConsumerStatefulWidget {
  const AppShell({super.key});

  @override
  ConsumerState<AppShell> createState() => _AppShellState();
}

class _AppShellState extends ConsumerState<AppShell> {
  int _index = 0;
  String? _configuredGroupId;
  String? _configuredUid;

  @override
  void didChangeDependencies() {
    super.didChangeDependencies();
    _configureNotifications();
  }

  Future<void> _configureNotifications() async {
    final user = FirebaseAuth.instance.currentUser;
    final groupId = ref.read(selectedGroupIdProvider);
    if (user == null || groupId == null) return;
    if (_configuredGroupId == groupId && _configuredUid == user.uid) return;

    _configuredGroupId = groupId;
    _configuredUid = user.uid;

    await NotificationInfraService.instance.configure(
      groupId: groupId,
      uid: user.uid,
      onTokenState: (token, stored) {
        ref.read(currentFcmTokenProvider.notifier).setToken(token);
        ref.read(tokenStoredProvider.notifier).setStored(stored);
      },
      onNavigateType: (type) {
        if (!mounted) return;
        if (type == 'notice') {
          setState(() => _index = 3);
        } else if (type == 'event') {
          setState(() => _index = 1);
        }
      },
      onError: (error) {
        ref.read(debugFirestoreErrorProvider.notifier).setError(error);
      },
    );
  }

  @override
  void dispose() {
    NotificationInfraService.instance.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final user = FirebaseAuth.instance.currentUser;
    final groupId = ref.watch(selectedGroupIdProvider);
    final statsPage = (user != null && groupId != null)
        ? StatsScreen(groupId: groupId, uid: user.uid)
        : const Center(child: Text('??怨뚰맟?熬곣뫗諭????깆젧???낅슣?섋땻??'));
    final pages = [
      const HomeScreen(),
      const EventsScreen(),
      statsPage,
      const NoticesScreen(),
      const MoreScreen(),
    ];

    return Scaffold(
      body: SafeArea(child: pages[_index]),
      bottomNavigationBar: BottomNavigationBar(
        currentIndex: _index,
        onTap: (i) => setState(() => _index = i),
        items: const [
          BottomNavigationBarItem(
            icon: Icon(Icons.home_outlined),
            label: 'Home',
          ),
          BottomNavigationBarItem(
            icon: Icon(Icons.event_outlined),
            label: 'Events',
          ),
          BottomNavigationBarItem(
            icon: Icon(Icons.stacked_bar_chart_outlined),
            label: 'Stats',
          ),
          BottomNavigationBarItem(
            icon: Icon(Icons.campaign_outlined),
            label: 'Notices',
          ),
          BottomNavigationBarItem(icon: Icon(Icons.more_horiz), label: 'More'),
        ],
      ),
    );
  }
}

class HomeScreen extends ConsumerWidget {
  const HomeScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final groupId = ref.watch(selectedGroupIdProvider);
    final user = FirebaseAuth.instance.currentUser;
    if (groupId == null || user == null) {
      return const Center(child: Text('??怨뚰맟?熬곣뫗諭????깆젧???낅슣?섋땻??'));
    }

    final lastError = ref.watch(debugFirestoreErrorProvider);
    final currentFcmToken = ref.watch(currentFcmTokenProvider);
    final tokenStored = ref.watch(tokenStoredProvider);

    final groupStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .snapshots();
    final memberStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('members')
        .doc(user.uid)
        .snapshots();
    final settingsStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('members')
        .doc(user.uid)
        .collection('notificationSettings')
        .doc('default')
        .snapshots();
    final eventsStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('events')
        .orderBy('startAt')
        .limit(10)
        .snapshots();
    final noticesStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('notices')
        .orderBy('createdAt', descending: true)
        .limit(10)
        .snapshots();

    return StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
      stream: groupStream,
      builder: (context, g) {
        if (g.hasError) {
          final msg = _friendlyError(g.error);
          ref.read(debugFirestoreErrorProvider.notifier).setError(msg);
          return Center(
            child: Padding(padding: const EdgeInsets.all(16), child: Text(msg)),
          );
        }
        if (!g.hasData) {
          return ListView(
            padding: const EdgeInsets.all(16),
            children: const [
              AppSkeleton(height: 28, width: 180),
              SizedBox(height: 12),
              AppSkeleton(height: 84),
              SizedBox(height: 12),
              AppSkeleton(height: 120),
              SizedBox(height: 12),
              AppSkeleton(height: 120),
            ],
          );
        }

        final groupName = g.data!.data()?['name'] as String? ?? groupId;
        final monthText = _currentPeriodKey().replaceAll('-', '.');
        final profileStream = FirebaseFirestore.instance
            .collection('users')
            .doc(user.uid)
            .snapshots();
        return ListView(
          padding: const EdgeInsets.all(16),
          children: [
            Row(
              children: [
                Expanded(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text(
                        groupName,
                        style: Theme.of(context).textTheme.headlineMedium,
                        maxLines: 2,
                        overflow: TextOverflow.ellipsis,
                      ),
                      const SizedBox(height: 4),
                      Text(
                        '$monthText ?筌먲퐢沅?,
                        style: Theme.of(context).textTheme.bodyMedium,
                      ),
                    ],
                  ),
                ),
                StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
                  stream: profileStream,
                  builder: (context, profileSnap) {
                    final data = profileSnap.data?.data();
                    final nickname = data?['nickname']?.toString() ?? '';
                    final photoUrl = data?['photoUrl']?.toString();
                    final initial = nickname.isNotEmpty
                        ? nickname[0].toUpperCase()
                        : null;
                    return Row(
                      children: [
                        InkWell(
                          borderRadius: BorderRadius.circular(20),
                          onTap: () => context.push('/profile'),
                          child: CircleAvatar(
                            radius: 16,
                            backgroundImage:
                                (photoUrl != null && photoUrl.isNotEmpty)
                                ? NetworkImage(photoUrl)
                                : null,
                            child: (photoUrl == null || photoUrl.isEmpty)
                                ? Text(initial ?? 'U')
                                : null,
                          ),
                        ),
                        IconButton(
                          onPressed: () =>
                              context.push('/notification-settings'),
                          icon: const Icon(Icons.settings_outlined),
                        ),
                      ],
                    );
                  },
                ),
              ],
            ),
            const SizedBox(height: 8),
            FutureBuilder<Map<String, String>>(
              future: HomeDashboardService.loadHomeKpi(groupId, user.uid),
              builder: (context, snapshot) {
                final kpi =
                    snapshot.data ??
                    const {
                      'attendanceRate': '-',
                      'unpaidCount': '-',
                      'upcomingCount': '-',
                    };
                return SingleChildScrollView(
                  scrollDirection: Axis.horizontal,
                  child: Row(
                    children: [
                      StatTile(
                        title: '?怨쀫츋?묐씤紐?,
                        value: kpi['attendanceRate'] ?? '-',
                      ),
                      StatTile(
                        title: '?????亦껋꼶梨뜻쾮?,
                        value: kpi['unpaidCount'] ?? '-',
                      ),
                      StatTile(
                        title: '???깆젧 ??源놁젧',
                        value: kpi['upcomingCount'] ?? '-',
                      ),
                    ],
                  ),
                );
              },
            ),
            const SizedBox(height: 8),
            const SectionHeader(
              title: '????????洹먮뿫???,
              icon: Icons.event_note_outlined,
            ),
            FutureBuilder<Map<String, String>>(
              future: HomeDashboardService.loadHomeEngagement(groupId, user.uid),
              builder: (context, engagement) {
                final data =
                    engagement.data ??
                    const {
                      'weeklyNoResponse': '-',
                      'attendanceStreak': '-',
                      'activityRank': '-',
                    };
                return AppCard(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      const Text('???????嶺뚣볦굣???????),
                      const SizedBox(height: 10),
                      Wrap(
                        spacing: 8,
                        runSpacing: 8,
                        children: [
                          StatusBadge(
                            label: '??쒕샍???${data['weeklyNoResponse']}嶺?,
                            tone: StatusBadgeTone.warning,
                          ),
                          StatusBadge(
                            label: '?怨쀫츋????⑥リ틭 ${data['attendanceStreak']}',
                            tone: StatusBadgeTone.success,
                          ),
                          StatusBadge(
                            label: '??類ｌ쭢 ??戮곕쭊 ${data['activityRank']}',
                            tone: StatusBadgeTone.primary,
                          ),
                        ],
                      ),
                    ],
                  ),
                );
              },
            ),
            const SizedBox(height: 8),
            StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
              stream: eventsStream,
              builder: (context, e) {
                if (e.hasError)
                  return AppCard(child: Text(_friendlyError(e.error)));
                if (!e.hasData) return const AppCard(child: Text('?釉띾쐞????노츎 繞?..'));

                final events = e.data!.docs
                    .where((d) => d.data()['isDeleted'] != true)
                    .toList();
                final upcoming = events
                    .where((d) {
                      final ts = d.data()['startAt'];
                      return ts is Timestamp &&
                          ts.toDate().isAfter(DateTime.now());
                    })
                    .take(2)
                    .toList();

                if (upcoming.isEmpty)
                  return const AppCard(child: Text('???깆젧????源놁젧????怨룸????덈펲.'));

                return Column(
                  children: [
                    for (final event in upcoming)
                      AppCard(
                        child:
                            StreamBuilder<
                              DocumentSnapshot<Map<String, dynamic>>
                            >(
                              stream: FirebaseFirestore.instance
                                  .collection('groups')
                                  .doc(groupId)
                                  .collection('events')
                                  .doc(event.id)
                                  .collection('responses')
                                  .doc(user.uid)
                                  .snapshots(),
                              builder: (context, rs) {
                                final response =
                                    rs.data?.data()?['response'] as String? ??
                                    'maybe';
                                final needsResponse =
                                    !rs.hasData ||
                                    !rs.data!.exists ||
                                    response == 'maybe';
                                final ts = event.data()['startAt'];
                                final dateText = ts is Timestamp
                                    ? _formatDate(ts.toDate())
                                    : '-';
                                final primaryPlace = _eventPrimaryPlace(
                                  event.data(),
                                );
                                final address = event
                                    .data()['address']
                                    ?.toString();
                                final mapQuery = _eventMapQuery(event.data());
                                return Align(
                                  alignment: Alignment.centerLeft,
                                  child: Column(
                                    crossAxisAlignment:
                                        CrossAxisAlignment.start,
                                    children: [
                                      Text(
                                        dateText,
                                        style: Theme.of(context)
                                            .textTheme
                                            .labelSmall
                                            ?.copyWith(
                                              fontWeight: FontWeight.w700,
                                            ),
                                      ),
                                      if (needsResponse) ...[
                                        const SizedBox(height: 6),
                                        const StatusBadge(
                                          label: '?筌먲퐢沅?,
                                          tone: StatusBadgeTone.warning,
                                        ),
                                      ],
                                      const SizedBox(height: 6),
                                      Text(
                                        event.data()['title'] as String? ??
                                            '(??類쏄콬 ??怨몃쾳)',
                                        style: Theme.of(
                                          context,
                                        ).textTheme.titleMedium,
                                        maxLines: 2,
                                        overflow: TextOverflow.ellipsis,
                                      ),
                                      const SizedBox(height: 4),
                                      Text(
                                        '???? $primaryPlace',
                                        style: Theme.of(
                                          context,
                                        ).textTheme.bodySmall,
                                        maxLines: 1,
                                        overflow: TextOverflow.ellipsis,
                                      ),
                                      if (address != null &&
                                          address.isNotEmpty &&
                                          address != primaryPlace) ...[
                                        const SizedBox(height: 2),
                                        Text(
                                          '?낅슣??? $address',
                                          style: Theme.of(
                                            context,
                                          ).textTheme.bodySmall,
                                          maxLines: 1,
                                          overflow: TextOverflow.ellipsis,
                                        ),
                                      ],
                                      const SizedBox(height: 8),
                                      if (mapQuery != null)
                                        Align(
                                          alignment: Alignment.centerLeft,
                                          child: TextButton.icon(
                                            onPressed: () =>
                                                MapLauncherService.openNaverMapSearch(
                                                  mapQuery,
                                                ),
                                            icon: const Icon(
                                              Icons.map_outlined,
                                              size: 16,
                                            ),
                                            label: const Text('?筌먦끉逾?),
                                          ),
                                        )
                                      else
                                        Align(
                                          alignment: Alignment.centerLeft,
                                          child: TextButton.icon(
                                            onPressed: () => AppSnackbar.show(
                                              context,
                                              message: '?낅슣????筌먲퐢沅뽪뤆?쎛 ??怨룸????덈펲.',
                                              type: AppSnackType.info,
                                            ),
                                            icon: const Icon(
                                              Icons.map_outlined,
                                              size: 16,
                                            ),
                                            label: const Text('?筌먦끉逾?),
                                          ),
                                        ),
                                      const SizedBox(height: 4),
                                      Wrap(
                                        spacing: 6,
                                        runSpacing: 6,
                                        children: [
                                          _ResponseButton(
                                            label: '?筌먦끉逾?,
                                            selected: response == 'maybe',
                                            onPressed: () => _writeResponse(
                                              groupId: groupId,
                                              eventId: event.id,
                                              uid: user.uid,
                                              response: 'maybe',
                                              context: context,
                                            ),
                                          ),
                                          _ResponseButton(
                                            label: '?筌먦끉逾?,
                                            selected: response == 'going',
                                            onPressed: () => _writeResponse(
                                              groupId: groupId,
                                              eventId: event.id,
                                              uid: user.uid,
                                              response: 'going',
                                              context: context,
                                            ),
                                          ),
                                          _ResponseButton(
                                            label: '?筌먦끉逾?,
                                            selected: response == 'notGoing',
                                            onPressed: () => _writeResponse(
                                              groupId: groupId,
                                              eventId: event.id,
                                              uid: user.uid,
                                              response: 'notGoing',
                                              context: context,
                                            ),
                                          ),
                                        ],
                                      ),
                                    ],
                                  ),
                                );
                              },
                            ),
                      ),
                  ],
                );
              },
            ),
            const SizedBox(height: 12),
            const SectionHeader(title: '?筌먦끉逾?, icon: Icons.campaign_outlined),
            StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
              stream: noticesStream,
              builder: (context, n) {
                if (n.hasError)
                  return AppCard(child: Text(_friendlyError(n.error)));
                if (!n.hasData) return const AppCard(child: Text('?釉띾쐞????노츎 繞?..'));

                final notices = n.data!.docs;
                final pinned = notices
                    .where((d) => d.data()['pinned'] == true)
                    .toList();
                final latest = notices.isNotEmpty ? notices.first : null;

                return AppCard(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      if (pinned.isNotEmpty)
                        Text(
                          '??μ쪠?? ${pinned.first.data()['title'] ?? '(??類쏄콬 ??怨몃쾳)'}',
                          maxLines: 1,
                          overflow: TextOverflow.ellipsis,
                        ),
                      if (latest != null) ...[
                        const SizedBox(height: 6),
                        Text(
                          '嶺뚣끉裕?? ${latest.data()['title'] ?? '(??類쏄콬 ??怨몃쾳)'}',
                          maxLines: 1,
                          overflow: TextOverflow.ellipsis,
                        ),
                      ],
                      if (pinned.isEmpty && latest == null)
                        const Text('??戮?뻣????ㅻ쾴??띠럾? ??怨룸????덈펲.'),
                      const SizedBox(height: 8),
                      StatusBadge(
                        label: '嶺뚣끉裕????ㅻ쾴? ${notices.length}濾?,
                        tone: StatusBadgeTone.primary,
                      ),
                    ],
                  ),
                );
              },
            ),
            const SizedBox(height: 12),
            const SectionHeader(title: '?筌먦끉逾?, icon: Icons.insights_outlined),
            FutureBuilder<Map<String, String>>(
              future: HomeDashboardService.loadMyHomeSummary(groupId, user.uid),
              builder: (context, summary) {
                final data = summary.data ?? const {'top3': '-', 'rank': '-'};
                return AppCard(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text('?怨쀫츋???TOP3: ${data['top3']}'),
                      const Divider(height: 16),
                      Text('????戮곕쭊: ${data['rank']}'),
                    ],
                  ),
                );
              },
            ),
            if (kEnableDebugPanel)
              StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
                stream: memberStream,
                builder: (context, m) {
                  return StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
                    stream: settingsStream,
                    builder: (context, ss) {
                      final settings = ss.data?.data();
                      final settingsSummary = settings == null
                          ? '?筌먲퐢沅?
                          : 'notice=${settings['noticeEnabled'] ?? true}, d1=${settings['eventReminderEnabled'] ?? true}, 13:00=${settings['noResponseReminderEnabled'] ?? true}';
                      return DebugPanelCard(
                        uid: user.uid,
                        selectedGroupId: groupId,
                        memberDocExists: m.data?.exists,
                        memberStatus: m.data?.data()?['status']?.toString(),
                        lastFirestoreError: lastError,
                        currentFcmToken: currentFcmToken,
                        tokenStored: tokenStored,
                        notificationSettingsSummary: settingsSummary,
                      );
                    },
                  );
                },
              ),
          ],
        );
      },
    );
  }
}

class EventsScreen extends ConsumerStatefulWidget {
  const EventsScreen({super.key});

  @override
  ConsumerState<EventsScreen> createState() => _EventsScreenState();
}

class _EventsScreenState extends ConsumerState<EventsScreen> {
  Future<void> _refresh(String groupId) async {
    await FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('events')
        .limit(1)
        .get();
  }

  @override
  Widget build(BuildContext context) {
    final groupId = ref.watch(selectedGroupIdProvider);
    final user = FirebaseAuth.instance.currentUser;
    if (groupId == null || user == null)
      return const Center(child: Text('??怨뚰맟?熬곣뫗諭????깆젧???낅슣?섋땻??'));

    final eventsStream = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('events')
        .orderBy('startAt')
        .snapshots();

    return StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
      stream: eventsStream,
      builder: (context, s) {
        if (s.hasError)
          return Center(
            child: Padding(
              padding: const EdgeInsets.all(16),
              child: Text(_friendlyError(s.error)),
            ),
          );
        if (!s.hasData) {
          return ListView(
            padding: const EdgeInsets.all(16),
            children: const [
              AppSkeleton(height: 24, width: 140),
              SizedBox(height: 12),
              AppSkeleton(height: 108),
              SizedBox(height: 8),
              AppSkeleton(height: 108),
            ],
          );
        }

        final now = DateTime.now();
        final allEvents = s.data!.docs
            .where((d) => d.data()['isDeleted'] != true)
            .toList();
        final upcomingEvents =
            allEvents.where((d) {
              final ts = d.data()['startAt'];
              return ts is Timestamp && !ts.toDate().isBefore(now);
            }).toList()..sort((a, b) {
              final at =
                  (a.data()['startAt'] as Timestamp?)?.toDate() ??
                  DateTime.fromMillisecondsSinceEpoch(0);
              final bt =
                  (b.data()['startAt'] as Timestamp?)?.toDate() ??
                  DateTime.fromMillisecondsSinceEpoch(0);
              return at.compareTo(bt);
            });
        final pastEvents =
            allEvents.where((d) {
              final ts = d.data()['startAt'];
              return ts is Timestamp && ts.toDate().isBefore(now);
            }).toList()..sort((a, b) {
              final at =
                  (a.data()['startAt'] as Timestamp?)?.toDate() ??
                  DateTime.fromMillisecondsSinceEpoch(0);
              final bt =
                  (b.data()['startAt'] as Timestamp?)?.toDate() ??
                  DateTime.fromMillisecondsSinceEpoch(0);
              return bt.compareTo(at);
            });
        final events = <QueryDocumentSnapshot<Map<String, dynamic>>>[
          ...upcomingEvents,
          ...pastEvents,
        ];
        if (events.isEmpty) {
          return EmptyState(
            icon: Icons.event_busy_outlined,
            title: '??源놁젧',
            description: '???깆젧????源놁젧????怨룸????덈펲.',
            actionLabel: '???됱Ŧ??μ쪠??,
            onAction: () => _refresh(groupId),
          );
        }

        return RefreshIndicator(
          onRefresh: () => _refresh(groupId),
          child: ListView.builder(
            physics: const AlwaysScrollableScrollPhysics(),
            padding: const EdgeInsets.all(16),
            itemCount: events.length + 1,
            itemBuilder: (context, i) {
              if (i == 0)
                return const SectionHeader(
                  title: '??????노츎 ??源놁젧',
                  icon: Icons.event_available_outlined,
                );
              final eventDoc = events[i - 1];
              final eventId = eventDoc.id;
              final title = eventDoc.data()['title'] as String? ?? '(??類쏄콬 ??怨몃쾳)';
              final ts = eventDoc.data()['startAt'];
              final dateText = ts is Timestamp ? _formatDate(ts.toDate()) : '-';
              final isPast = ts is Timestamp && ts.toDate().isBefore(now);
              final primaryPlace = _eventPrimaryPlace(eventDoc.data());
              final address = eventDoc.data()['address']?.toString();
              final mapQuery = _eventMapQuery(eventDoc.data());

              return AnimatedListEntry(
                index: i,
                child: AppCard(
                  borderColor: isPast ? AppTheme.warning : null,
                  child: InkWell(
                    onTap: () => context.push('/event/$eventId'),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          dateText,
                          style: Theme.of(context).textTheme.labelSmall
                              ?.copyWith(fontWeight: FontWeight.w700),
                        ),
                        const SizedBox(height: 4),
                        Text(
                          title,
                          style: Theme.of(context).textTheme.titleMedium,
                          maxLines: 2,
                          overflow: TextOverflow.ellipsis,
                        ),
                        if (isPast) ...[
                          const SizedBox(height: 6),
                          const StatusBadge(
                            label: '?筌먦끉逾?,
                            tone: StatusBadgeTone.warning,
                          ),
                        ],
                        const SizedBox(height: 4),
                        Row(
                          children: [
                            Expanded(
                              child: Text(
                                '???? $primaryPlace',
                                style: Theme.of(context).textTheme.bodySmall,
                                maxLines: 1,
                                overflow: TextOverflow.ellipsis,
                              ),
                            ),
                            IconButton(
                              onPressed: () {
                                if (mapQuery == null) {
                                  AppSnackbar.show(
                                    context,
                                    message: '?낅슣????筌먲퐢沅뽪뤆?쎛 ??怨룸????덈펲.',
                                    type: AppSnackType.info,
                                  );
                                  return;
                                }
                                MapLauncherService.openNaverMapSearch(mapQuery);
                              },
                              tooltip: '?筌먦끉逾?,
                              icon: const Icon(Icons.map_outlined, size: 18),
                              visualDensity: VisualDensity.compact,
                            ),
                          ],
                        ),
                        if (address != null &&
                            address.isNotEmpty &&
                            address != primaryPlace) ...[
                          const SizedBox(height: 2),
                          Text(
                            '?낅슣??? $address',
                            style: Theme.of(context).textTheme.bodySmall,
                            maxLines: 1,
                            overflow: TextOverflow.ellipsis,
                          ),
                        ],
                        const SizedBox(height: 8),
                        Wrap(
                          spacing: 6,
                          runSpacing: 6,
                          children: [
                            _ResponseButton(
                              label: '亦껋꼶梨??,
                              selected: false,
                              onPressed: isPast
                                  ? null
                                  : () => _writeResponse(
                                      groupId: groupId,
                                      eventId: eventId,
                                      uid: user.uid,
                                      response: 'maybe',
                                      context: context,
                                    ),
                            ),
                            _ResponseButton(
                              label: '嶺뚣볦굣??,
                              selected: false,
                              onPressed: isPast
                                  ? null
                                  : () => _writeResponse(
                                      groupId: groupId,
                                      eventId: eventId,
                                      uid: user.uid,
                                      response: 'going',
                                      context: context,
                                    ),
                            ),
                            _ResponseButton(
                              label: '?釉띾쐠揶?,
                              selected: false,
                              onPressed: isPast
                                  ? null
                                  : () => _writeResponse(
                                      groupId: groupId,
                                      eventId: eventId,
                                      uid: user.uid,
                                      response: 'notGoing',
                                      context: context,
                                    ),
                            ),
                          ],
                        ),
                      ],
                    ),
                  ),
                ),
              );
            },
          ),
        );
      },
    );
  }
}

class EventDetailScreen extends ConsumerStatefulWidget {
  const EventDetailScreen({super.key, required this.eventId});

  final String eventId;

  @override
  ConsumerState<EventDetailScreen> createState() => _EventDetailScreenState();
}

class _EventDetailScreenState extends ConsumerState<EventDetailScreen> {
  bool _showAttendance = false;

  @override
  Widget build(BuildContext context) {
    final groupId = ref.watch(selectedGroupIdProvider);
    final user = FirebaseAuth.instance.currentUser;
    if (groupId == null || user == null) {
      return const Scaffold(body: Center(child: Text('??怨뚰맟?熬곣뫗諭????깆젧???낅슣?섋땻??')));
    }

    final eventRef = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('events')
        .doc(widget.eventId);
    final myMemberRef = FirebaseFirestore.instance
        .collection('groups')
        .doc(groupId)
        .collection('members')
        .doc(user.uid);
    final myResponseRef = eventRef.collection('responses').doc(user.uid);

    return StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
      stream: myMemberRef.snapshots(),
      builder: (context, myMember) {
        final permission = PermissionService.fromMemberData(
          myMember.data?.data(),
        );
        final canViewAttendance =
            permission.canManageMembers() || permission.canManageEvents();

        return Scaffold(
          appBar: AppBar(
            title: const Row(
              children: [
                Icon(Icons.event_note_outlined, size: 18),
                SizedBox(width: 6),
                Text('??源놁젧 ??⑤㈇??),
              ],
            ),
          ),
          body: StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
            stream: eventRef.snapshots(),
            builder: (context, eventSnap) {
              if (eventSnap.hasError)
                return Center(child: Text(_friendlyError(eventSnap.error)));
              if (!eventSnap.hasData)
                return const Center(child: CircularProgressIndicator());
              final data = eventSnap.data!.data();
              if (data == null || data['isDeleted'] == true) {
                return const Center(child: Text('???????源놁젧???낅퉵??'));
              }

              final title = data['title']?.toString() ?? '(??類쏄콬 ??怨몃쾳)';
              final ts = data['startAt'];
              final dateText = ts is Timestamp ? _formatDate(ts.toDate()) : '-';
              final isPast =
                  ts is Timestamp && ts.toDate().isBefore(DateTime.now());
              final primaryPlace = _eventPrimaryPlace(data);
              final address = data['address']?.toString();
              final mapQuery = _eventMapQuery(data);

              return ListView(
                padding: const EdgeInsets.all(16),
                children: [
                  AppCard(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          dateText,
                          style: Theme.of(context).textTheme.labelSmall
                              ?.copyWith(fontWeight: FontWeight.w700),
                        ),
                        const SizedBox(height: 6),
                        Text(
                          title,
                          style: Theme.of(context).textTheme.headlineMedium,
                        ),
                        const SizedBox(height: 6),
                        Text(
                          '???? $primaryPlace',
                          style: Theme.of(context).textTheme.bodyMedium,
                        ),
                        if (address != null &&
                            address.isNotEmpty &&
                            address != primaryPlace) ...[
                          const SizedBox(height: 4),
                          Text(
                            '?낅슣??? $address',
                            style: Theme.of(context).textTheme.bodySmall,
                          ),
                        ],
                        const SizedBox(height: 8),
                        OutlinedButton.icon(
                          onPressed: () {
                            if (mapQuery == null) {
                              AppSnackbar.show(
                                context,
                                message: '?낅슣????筌먲퐢沅뽪뤆?쎛 ??怨룸????덈펲.',
                                type: AppSnackType.info,
                              );
                              return;
                            }
                            MapLauncherService.openNaverMapSearch(mapQuery);
                          },
                          icon: const Icon(Icons.map_outlined),
                          label: const Text('嶺뚯솘??????⒱뵛'),
                        ),
                        const SizedBox(height: 12),
                        StreamBuilder<DocumentSnapshot<Map<String, dynamic>>>(
                          stream: myResponseRef.snapshots(),
                          builder: (context, r) {
                            final selected =
                                r.data?.data()?['response'] as String? ??
                                'maybe';
                            return Wrap(
                              spacing: 6,
                              runSpacing: 6,
                              children: [
                                _ResponseButton(
                                  label: '亦껋꼶梨??,
                                  selected: selected == 'maybe',
                                  onPressed: isPast
                                      ? null
                                      : () => _writeResponse(
                                          groupId: groupId,
                                          eventId: widget.eventId,
                                          uid: user.uid,
                                          response: 'maybe',
                                          context: context,
                                        ),
                                ),
                                _ResponseButton(
                                  label: '嶺뚣볦굣??,
                                  selected: selected == 'going',
                                  onPressed: isPast
                                      ? null
                                      : () => _writeResponse(
                                          groupId: groupId,
                                          eventId: widget.eventId,
                                          uid: user.uid,
                                          response: 'going',
                                          context: context,
                                        ),
                                ),
                                _ResponseButton(
                                  label: '?釉띾쐠揶?,
                                  selected: selected == 'notGoing',
                                  onPressed: isPast
                                      ? null
                                      : () => _writeResponse(
                                          groupId: groupId,
                                          eventId: widget.eventId,
                                          uid: user.uid,
                                          response: 'notGoing',
                                          context: context,
                                        ),
                                ),
                              ],
                            );
                          },
                        ),
                        if (isPast) ...[
                          const SizedBox(height: 8),
                          const Text('嶺뚯솘?????源놁젧???낅퉵?? ??얜Ŧ堉???瑜곸젧?????ル┰??紐껊퉵??'),
                        ],
                      ],
                    ),
                  ),
                  if (canViewAttendance) ...[
                    AppCard(
                      child: ListTile(
                        contentPadding: EdgeInsets.zero,
                        leading: const Icon(
                          Icons.assignment_turned_in_outlined,
                        ),
                        title: const Text('嶺뚣볦굣???熬곥굦??),
                        subtitle: const Text('嶺뚮、?뉓떋?????얜Ŧ堉??筌먦끉逾?),
                        trailing: Icon(
                          _showAttendance
                              ? Icons.expand_less
                              : Icons.expand_more,
                        ),
                        onTap: () =>
                            setState(() => _showAttendance = !_showAttendance),
                      ),
                    ),
                    if (_showAttendance)
                      StreamBuilder<QuerySnapshot<Map<String, dynamic>>>(
                        stream: FirebaseFirestore.instance
                            .collection('groups')
                            .doc(groupId)
                            .collection('members')
                            .where('status', isEqualTo: 'active')
                            .snapshots(),
                        builder: (context, membersSnap) {
                          if (membersSnap.hasError)
                            return AppCard(
                              child: Text(_friendlyError(membersSnap.error)),
                            );
                          if (!membersSnap.hasData)
                            return const AppCard(
                              child: Text('嶺뚣볦굣???熬곥굦???釉띾쐞????노츎 繞?..'),
                            );

                          return StreamBuilder<
                            QuerySnapshot<Map<String, dynamic>>
                          >(
                            stream: eventRef
                                .collection('responses')
                                .snapshots(),
                            builder: (context, responsesSnap) {
                              if (responsesSnap.hasError)
                                return AppCard(
                                  child: Text(
                                    _friendlyError(responsesSnap.error),
                                  ),
                                );
                              if (!responsesSnap.hasData)
                                return const AppCard(
                                  child: Text('?筌먦끉逾??釉띾쐞????노츎 繞?..'),
                                );

                              final members = membersSnap.data!.docs;
                              final responseByUid =
                                  <String, Map<String, dynamic>>{
                                    for (final r in responsesSnap.data!.docs)
                                      r.id: r.data(),
                                  };

                              var going = 0;
                              var maybe = 0;
                              var notGoing = 0;
                              var noResponse = 0;

                              final rows = <_AttendanceRowData>[];
                              for (final m in members) {
                                final uid = m.id;
                                final nickname =
                                    m
                                        .data()['public']?['nickname']
                                        ?.toString() ??
                                    uid;
                                final responseData = responseByUid[uid];
                                final response = responseData?['response']
                                    ?.toString();
                                final respondedAt =
                                    responseData?['respondedAt'];
                                final responseLabel = switch (response) {
                                  'going' => '?筌먦끉逾?,
                                  'maybe' => '?筌먦끉逾?,
                                  'notGoing' => '?筌먦끉逾?,
                                  _ => '亦껋꼶梨???,
                                };

                                switch (response) {
                                  case 'going':
                                    going++;
                                    break;
                                  case 'maybe':
                                    maybe++;
                                    break;
                                  case 'notGoing':
                                    notGoing++;
                                    break;
                                  default:
                                    noResponse++;
                                    break;
                                }

                                rows.add(
                                  _AttendanceRowData(
                                    nickname: nickname,
                                    responseLabel: responseLabel,
                                    respondedAt: respondedAt is Timestamp
                                        ? _formatDate(respondedAt.toDate())
                                        : null,
                                  ),
                                );
                              }

                              return AppCard(
                                child: Column(
                                  crossAxisAlignment: CrossAxisAlignment.start,
                                  children: [
                                    Wrap(
                                      spacing: 8,
                                      runSpacing: 8,
                                      children: [
                                        StatusBadge(
                                          label: '?筌먦끉逾?$going',
                                          tone: StatusBadgeTone.success,
                                        ),
                                        StatusBadge(
                                          label: '?筌먦끉逾?$maybe',
                                          tone: StatusBadgeTone.warning,
                                        ),
                                        StatusBadge(
                                          label: '?筌먦끉逾?$notGoing',
                                          tone: StatusBadgeTone.danger,
                                        ),
                                        StatusBadge(
                                          label: '?筌먦끉逾?noResponse',
                                          tone: StatusBadgeTone.primary,
                                        ),
                                      ],
                                    ),
                                    const SizedBox(height: 12),
                                    for (final row in rows)
                                      ListTile(
                                        contentPadding: EdgeInsets.zero,
                                        dense: true,
                                        title: Text(row.nickname),
                                        subtitle: row.respondedAt == null
                                            ? null
                                            : Text(row.respondedAt!),
                                        trailing: Text(row.responseLabel),
                                      ),
                                  ],
                                ),
                              );
                            },
                          );
                        },
                      ),
                  ],
                ],
              );
            },
          ),
        );
      },
    );
  }
}

